<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="28dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/textBackPostCreate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_back"
            android:textColor="@color/accent_color"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            style="@style/AppScreenTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/post_create_title"
            />

        <View
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:layout_marginTop="10dp"
            android:background="@color/accent_color" />

        <TextView
            style="@style/AppScreenSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/post_create_subtitle" />

        <com.google.android.material.card.MaterialCardView
            style="@style/AppFormCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/AppSectionChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_post_type" />

                <RadioGroup
                    android:id="@+id/radioGroupPostType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@color/soft_surface"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <RadioButton
                        android:id="@+id/radioPostAdoption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="@string/post_type_adoption" />

                    <RadioButton
                        android:id="@+id/radioPostLost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/post_type_lost" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/AppFormCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/AppFilledInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_animal_name"
                    >

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editPostAnimalName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="6dp"
                    android:text="@string/label_species"
                    android:textColor="@color/primary_text"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerPostSpecies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_spinner" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/AppFilledInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="@string/hint_breed"
                    >

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editPostBreed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/AppFilledInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="@string/hint_age"
                    >

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editPostAge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/AppFilledInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="@string/hint_post_description"
                    >

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editPostDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top|start"
                        android:inputType="textMultiLine"
                        android:minLines="4" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/AppFilledInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="@string/hint_contact_phone"
                    >

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editPostContactPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/label_pet_image"
                    android:textColor="@color/primary_text"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/imagePostPreview"
                    android:layout_width="match_parent"
                    android:layout_height="210dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_spinner"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery" />

                <com.google.android.material.button.MaterialButton
                    style="@style/AppSecondaryButton"
                    android:id="@+id/buttonSelectImage"
                    android:layout_width="match_parent"
                    android:layout_marginTop="12dp"
                    android:text="@string/button_select_image"
                    />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/layoutLostLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                style="@style/AppFormCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        style="@style/AppSectionChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lost_location_title" />

                    <TextView
                        android:id="@+id/textLocationStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/location_not_captured"
                        android:textColor="@color/secondary_text" />

                    <com.google.android.material.button.MaterialButton
                        style="@style/AppPrimaryButton"
                        android:id="@+id/buttonCaptureLocation"
                        android:layout_width="match_parent"
                        android:layout_marginTop="14dp"
                        android:text="@string/button_capture_location"
                        />

                    <com.google.android.material.button.MaterialButton
                        style="@style/AppSecondaryButton"
                        android:id="@+id/buttonSelectLocationOnMap"
                        android:layout_width="match_parent"
                        android:layout_marginTop="10dp"
                        android:text="@string/button_select_location_map"
                        />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/AppFilledInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="@string/hint_lost_location_reference">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editLostLocationReference"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine"
                            android:minLines="3" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            style="@style/AppPrimaryButton"
            android:id="@+id/buttonCreatePost"
            android:layout_width="match_parent"
            android:layout_marginTop="24dp"
            android:text="@string/button_publish_post"
            android:textSize="17sp" />
    </LinearLayout>
</ScrollView>
